# Public browser-safe values only.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Demo mode remains available as a clearly labeled, fictional browser fallback.
NEXT_PUBLIC_DEMO_MODE=true

# Optional local, private AI. The public server cannot reach a laptop-local
# Ollama process unless a separately secured model endpoint is configured.
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=qwen2.5:7b
