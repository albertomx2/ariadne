# Public browser-safe values only.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Demo mode remains available as a clearly labeled, fictional browser fallback.
NEXT_PUBLIC_DEMO_MODE=true

# Vercel deployments use their automatically injected VERCEL_OIDC_TOKEN.
# An AI Gateway API key is optional outside Vercel; never expose it with
# a NEXT_PUBLIC_ prefix.
AI_GATEWAY_API_KEY=
AI_GATEWAY_MODEL=openai/gpt-5-mini

# Optional local development fallback when no Gateway token is available.
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=qwen2.5:7b
