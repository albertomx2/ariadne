# Public browser-safe values only.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Demo mode remains available as a clearly labeled, fictional browser fallback.
NEXT_PUBLIC_DEMO_MODE=true

# Public hackathon deployments use a fine-grained GitHub token with only the
# account-level "Models: read" permission. Never use a NEXT_PUBLIC_ prefix.
GITHUB_MODELS_TOKEN=
GITHUB_MODELS_MODEL=openai/gpt-4.1-mini

# Optional hosted alternative. Vercel may inject VERCEL_OIDC_TOKEN.
AI_GATEWAY_API_KEY=
AI_GATEWAY_MODEL=openai/gpt-5-mini

# Optional local fallback when no hosted token is available.
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=qwen2.5:7b
